NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database provider: supabase, postgres, mysql, mongodb, sqlite, or memory.
DATABASE_PROVIDER=supabase
DATABASE_URL=

# Supabase server-side credentials. Use the service_role key only on the server.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Auth
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Optional client override. Leave unset when Vite proxies /api to the local server.
VITE_API_BASE_URL=
